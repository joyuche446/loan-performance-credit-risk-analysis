    <worksheet name='Bad Loan Funded Amount'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#ffffff' fontname='Segoe UI Semibold' fontsize='9'>Bad Loan Funded Amount</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Bank Loan SQL2 (Bank Loan SQL2)' name='federated.02bapp10spx5te19axciv0uohof1' />
          </datasources>
          <datasource-dependencies datasource='federated.02bapp10spx5te19axciv0uohof1'>
            <column caption='Bad Loan Funded Amount ' datatype='integer' name='[Good Loan Funded Amount (copy)_1018750884237318]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF([Loan Status (group)])=&quot;Bad Loan&quot; THEN [loan_amount] END)' />
            </column>
            <column caption='Good vs Bad Loan' datatype='string' name='[Loan Status (group)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[loan_status]' new-bin='true'>
                <bin default-name='false' value='&quot;Bad Loan&quot;'>
                  <value>&quot;Charged Off&quot;</value>
