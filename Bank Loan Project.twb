      <aliases enabled='yes' />
      <column caption='% Bad Loan Applications' datatype='real' name='[% Good Loan Applications (copy)_1018750882738181]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Loan Status (group)] = &quot;Bad Loan&quot; THEN [id] END)&#13;&#10;/ COUNT([id])' />
      </column>
      <column caption='Average DTI' datatype='real' name='[Average Interest Rate (copy)_0282077670293524]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([dti])' />
      </column>
      <column caption='MTD Total Loan App' datatype='integer' name='[Calculation_0282077632892928]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;    IF MONTH([issue_date]) = [Parameters].[Parameter 1]&#13;&#10;    AND YEAR([issue_date]) = 2021&#13;&#10;    THEN [id]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='MONTH(issue_date)' datatype='integer' name='[Calculation_0282077635903489]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MONTH([issue_date])' />
      </column>
      <column caption='MoM Total Loan Application' datatype='real' default-format='p0.0%' name='[Calculation_0282077641867267]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(([Calculation_0282077632892928] - [MTD Total Loan App (copy)_0282077638668290])&#13;&#10;/&#13;&#10;[MTD Total Loan App (copy)_0282077638668290])' />
      </column>
      <column caption='AVG(0)' datatype='real' name='[Calculation_0282077807128601]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(0)' />
      </column>
      <column caption='Total Loan Applications' datatype='integer' name='[Calculation_0607807710298112]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([id])' />
